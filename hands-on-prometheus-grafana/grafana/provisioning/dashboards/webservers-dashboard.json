      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (server, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P50 {{ server }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (server, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 {{ server }}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (server, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99 {{ server }}",
          "refId": "C"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
